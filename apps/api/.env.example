# Postgres connection (Neon prod, local docker for dev)
DATABASE_URL=postgresql+psycopg://derby:derby@localhost:5432/derby

# JWT
JWT_SECRET=change-me-to-a-32-byte-random-string
JWT_ALGORITHM=HS256
SESSION_DAYS=30

# App
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Resend
RESEND_API_KEY=
EMAIL_FROM="Sun Oracle <noreply@xoware.com>"

# Admin bootstrap (comma-separated emails granted is_admin on first login)
ADMIN_EMAILS=dominickj.giordano@gmail.com

# Polling window (UTC)
POLL_ENABLED=false
POLL_WINDOW_START_UTC=2026-05-02T16:00:00Z
POLL_WINDOW_END_UTC=2026-05-03T00:00:00Z
POLL_INTERVAL_SECONDS=120
POLL_PROVIDER=fake
